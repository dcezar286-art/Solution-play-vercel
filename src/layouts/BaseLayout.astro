---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import RevealInit from "../components/RevealInit.astro";
import NetworkBackdrop from "../components/NetworkBackdrop.astro";
import EntropyBackdrop from "../components/EntropyBackdrop.astro";

interface Props {
  title: string;
  description?: string;
  /** Ativa secções em ecrã completo com scroll-snap (ex.: home). */
  snapSections?: boolean;
  /** Lenis + GSAP ScrollTrigger (incompatível com scroll-snap no html). */
  homeMotion?: boolean;
  /** SPA por slides — sem scroll vertical global. */
  homeSpa?: boolean;
}

const {
  title,
  description = "Amostra visual — Solution Play (TI e telecom). Demonstração para Vercel.",
  snapSections = false,
  homeMotion = false,
  homeSpa = false,
} = Astro.props;

const useSnapLayout = snapSections && !homeMotion && !homeSpa;
const useHomeFx = homeMotion || homeSpa;
---

<!doctype html>
<html
  lang="pt-BR"
  class:list={[{ "snap-site-html": useSnapLayout, "home-motion": useHomeFx, "home-spa": homeSpa }]}
  data-spa-slide={homeSpa ? "hero" : undefined}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,600;0,9..40,700&family=Sora:wght@600;700&family=Syne:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class:list={["page-shell", { "snap-site-body": useSnapLayout }]}>
    <script is:inline>
      document.addEventListener("astro:page-load", () => {
        if (!document.documentElement.classList.contains("home-spa")) {
          window.__solutionPlaySpaDestroy?.();
          window.__solutionPlayEntropyDestroy?.();
        }
        if (!document.documentElement.classList.contains("home-motion")) {
          window.__solutionPlayLenisDestroy?.();
        }
      });
    </script>
    <a class="skip-link" href="#conteudo-principal">Ir para o conteúdo</a>
    <div class="grain-overlay" aria-hidden="true"></div>
    {homeSpa ? <EntropyBackdrop /> : <NetworkBackdrop />}
    <slot />
    <RevealInit />
  </body>
</html>
