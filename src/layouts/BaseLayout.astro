---
import "../styles/global.css";
import RevealInit from "../components/RevealInit.astro";
import NetworkBackdrop from "../components/NetworkBackdrop.astro";
import SpaBackground from "../components/SpaBackground.astro";
import { brand } from "../data/marketingContent";
import { siteSeo } from "../data/seo";

interface Props {
  title: string;
  description?: string;
  /** URL absoluta da imagem para redes sociais (opcional). */
  ogImage?: string;
  /** Ativa secções em ecrã completo com scroll-snap (ex.: home). */
  snapSections?: boolean;
  /** Lenis + GSAP ScrollTrigger (incompatível com scroll-snap no html). */
  homeMotion?: boolean;
  /** SPA por slides — sem scroll vertical global. */
  homeSpa?: boolean;
  /** Preload WebP da logo do hero (LCP). */
  heroLogoPreload?: string;
  /** Preload do fundo estático do hero. */
  heroBgPreload?: string;
}

const {
  title,
  description = siteSeo.defaultDescription,
  ogImage,
  snapSections = false,
  homeMotion = false,
  homeSpa = false,
  heroLogoPreload,
  heroBgPreload,
} = Astro.props;

const useSnapLayout = snapSections && !homeMotion && !homeSpa;
const useHomeFx = homeMotion || homeSpa;
const canonicalUrl = new URL(Astro.url.pathname, siteSeo.siteUrl).href;
const ogImageUrl = ogImage ?? new URL("/og-image.png", siteSeo.siteUrl).href;
const googleVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
---

<!doctype html>
<html
  lang="pt-BR"
  class:list={[{ "snap-site-html": useSnapLayout, "home-motion": useHomeFx, "home-spa": homeSpa }]}
  data-spa-slide={homeSpa ? "hero" : undefined}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonicalUrl} />
    {googleVerification ? (
      <meta name="google-site-verification" content={googleVerification} />
    ) : null}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteSeo.siteName} />
    <meta property="og:locale" content={siteSeo.locale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content={siteSeo.twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {heroBgPreload ? (
      <link rel="preload" as="image" href={heroBgPreload} type="image/webp" fetchpriority="high" />
    ) : null}
    {heroLogoPreload ? (
      <link rel="preload" as="image" href={heroLogoPreload} fetchpriority="low" />
    ) : null}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,600;0,9..40,700&family=Sora:wght@600;700&family=Syne:wght@600;700;800&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,600;0,9..40,700&family=Sora:wght@600;700&family=Syne:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class:list={["page-shell", { "snap-site-body": useSnapLayout }]}>
    <script is:inline>
      document.addEventListener("astro:page-load", () => {
        if (!document.documentElement.classList.contains("home-spa")) {
          window.__solutionPlaySpaDestroy?.();
          window.__solutionPlayEntropyDestroy?.();
          window.__solutionPlayBeamsDestroy?.();
          window.__solutionPlayHeroShaderDestroy?.();
          window.__solutionPlayHeroRootsDestroy?.();
          window.__solutionPlayCommercialDottedDestroy?.();
          window.__solutionPlayNeuralDestroy?.();
        }
        if (!document.documentElement.classList.contains("home-motion")) {
          window.__solutionPlayLenisDestroy?.();
        }
      });
    </script>
    <a class="skip-link" href="#conteudo-principal">Ir para o conteúdo</a>
    <div class="grain-overlay" aria-hidden="true"></div>
    {homeSpa ? <SpaBackground /> : <NetworkBackdrop />}
    <slot />
    <footer class="site-footer-cnpj" aria-label="Identificação da empresa">
      <p class="site-footer-cnpj__line">CNPJ {brand.cnpj}</p>
    </footer>
    <RevealInit />
  </body>
</html>
