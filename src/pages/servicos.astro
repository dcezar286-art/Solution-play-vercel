---
import BaseLayout from "../layouts/BaseLayout.astro";
import logoUrl from "../../LOGO/SolutionPlay-removebg-preview.png?url";
---

<BaseLayout
  title="Serviços — Solution Play (amostra)"
  description="Lista resumida dos escopos TI e telecom da amostra Solution Play."
>
  <header class="site-header site-header--studio">
    <div class="wrap inner">
      <a class="logo logo--studio" href="/" aria-label="Solution Play — início">
        <img class="logo__mark" src={logoUrl} alt="" width="40" height="40" decoding="async" />
        <span class="logo__text">Solution <span class="logo__accent">Play</span></span>
      </a>
      <nav class="nav nav--studio" aria-label="Principal">
        <a href="/">Início</a>
        <a href="/#servicos-heading">Serviços (abas)</a>
        <a href="/#contato-heading">Contato</a>
      </nav>
      <a
        class="btn btn-primary btn--studio"
        href="https://wa.me/5511937415034"
        target="_blank"
        rel="noopener noreferrer">WhatsApp</a>
    </div>
  </header>

  <main id="conteudo-principal" class="wrap" style="padding: 3rem 0 4rem">
    <h1 style="font-size: clamp(1.75rem, 3vw, 2.25rem); margin-top: 0" transition:animate="fade">
      Página Serviços (opcional)
    </h1>
    <p style="color: var(--text-muted); max-width: 60ch">
      Esta página complementa a home com uma visão linear dos mesmos escopos. O conteúdo institucional completo
      (contatos reais, CNPJ) permanece no site oficial do cliente.
    </p>

    <section class="section" style="padding-left: 0; padding-right: 0" aria-labelledby="ti-lista" data-reveal>
      <h2 id="ti-lista">TI — empresas</h2>
      <ul style="color: var(--text-muted); line-height: 1.8">
        <li>Implantação de servidores</li>
        <li>Active Directory</li>
        <li>File Server</li>
        <li>Proxy Web e Squid</li>
        <li>Monitoramento (Zabbix, Grafana)</li>
        <li>DNS recursivo</li>
        <li>VPNs</li>
      </ul>
    </section>

    <section
      class="section"
      style="padding-left: 0; padding-right: 0; --reveal-delay: 80ms"
      aria-labelledby="tele-lista"
      data-reveal
    >
      <h2 id="tele-lista">Telecom — provedores</h2>
      <ul style="color: var(--text-muted); line-height: 1.8">
        <li>Implantação de roteadores</li>
        <li>Camada 3: OSPF, BGP, MPLS</li>
        <li>Switches L2: VLANs de serviço e transporte, QinQ, translation, entre outros</li>
      </ul>
    </section>

    <p style="margin-top: 2rem">
      <a class="btn btn-primary" href="/#contato-heading">Voltar ao formulário</a>
    </p>
  </main>

  <footer class="site-footer">
    <div class="wrap cols">
      <p style="margin: 0">Solution Play — amostra Vercel · <a href="/">Início</a></p>
    </div>
  </footer>
</BaseLayout>
