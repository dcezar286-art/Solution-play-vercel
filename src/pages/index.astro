---
import BaseLayout from "../layouts/BaseLayout.astro";
import MarqueeStrip from "../components/MarqueeStrip.astro";
import ServiceTabs from "../components/ServiceTabs.astro";
import LeadForm from "../components/LeadForm.astro";
import HomeSpaMotion from "../components/HomeSpaMotion.astro";
import InteractiveTopNav from "../components/InteractiveTopNav.astro";
import BenefitsRow from "../components/BenefitsRow.astro";
import HeroShaderBackdrop from "../components/HeroShaderBackdrop.astro";
import CommercialDottedBackdrop from "../components/CommercialDottedBackdrop.astro";
import NeuralBackdrop from "../components/NeuralBackdrop.astro";
import CommercialMSP from "../components/CommercialMSP.astro";
import { brand, hero, commercial, contact } from "../data/marketingContent";
import logoUrl from "../../LOGO/LOGO BRANCA.png?url";
---

<BaseLayout title="Solution Play — Soluções de TI completas" homeSpa={true}>
  <div class="spa-layout">
    <InteractiveTopNav />

    <div class="spa-stage">
      <main id="conteudo-principal" class="spa-main">
        <div class="spa-viewport">
          <div class="spa-track">
            <article class="spa-slide is-active" data-slide="hero" aria-hidden="false">
              <div class="spa-slide__inner hero hero--studio" aria-labelledby="hero-heading">
                <HeroShaderBackdrop />
                <div class="hero-studio-atmos spa-hero-deco" aria-hidden="true">
                  <span class="hero-studio-deco hero-studio-deco--mass">INFRA</span>
                  <span class="hero-studio-deco hero-studio-deco--trace">BGP · MPLS · AD</span>
                </div>
                <div class="wrap hero-studio-grid hero-studio-grid--single">
                  <div class="hero-studio-copy">
                    <div class="hero-brand-row">
                      <img
                        class="hero-brand-mark"
                        src={logoUrl}
                        alt=""
                        width="64"
                        height="64"
                        decoding="async"
                        fetchpriority="high"
                        loading="eager"
                      />
                      <p class="hero-slogan">
                        Tecnologia que resolve. Soluções que <span class="hero-slogan__accent">impulsionam</span>.
                      </p>
                    </div>
                    <h1 id="hero-heading" class="hero-mega">
                      {
                        hero.headlineLines.map((line) => (
                          <span
                            class:list={[
                              "hero-mega__line",
                              line.variant === "outline" && "hero-mega__line--outline",
                              line.variant === "accent" && "hero-mega__line--accent",
                            ]}
                          >
                            {line.text}
                          </span>
                        ))
                      }
                    </h1>
                    <p class="hero-lead hero-lead--studio">{hero.lead}</p>
                    <BenefitsRow />
                    <div class="hero-studio-foot">
                      <div class="hero-ctas">
                        <button type="button" class="btn btn-primary" data-slide-jump="contact">Formulário</button>
                        <button type="button" class="btn btn-ghost" data-slide-jump="services">Nossos serviços</button>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </article>

            <article class="spa-slide" data-slide="services" aria-hidden="true">
              <div class="spa-slide__inner spa-slide__inner--services">
                <div class="services-slide-content">
                  <MarqueeStrip />
                  <ServiceTabs />
                </div>
              </div>
            </article>

            <article class="spa-slide" data-slide="commercial" aria-hidden="true">
              <div class="spa-slide__inner section commercial commercial--studio" aria-labelledby="comercial-heading">
                <CommercialDottedBackdrop />
                <div class="wrap commercial-inner commercial-inner--above commercial-inner--spa">
                  <div class="commercial-main">
                    <h2 id="comercial-heading" class="section-eyebrow commercial-page-title">
                      {commercial.headline}
                    </h2>
                    <CommercialMSP />
                  </div>
                </div>
              </div>
            </article>

            <article class="spa-slide" data-slide="contact" aria-hidden="true">
              <div class="spa-slide__inner section lead-section lead-section--studio spa-slide__inner--contact" aria-labelledby="contato-heading">
                <NeuralBackdrop slide="contact" color="#22d3ee" />
                <div class="wrap lead-grid contact-slide-content">
                  <div>
                    <p class="section-eyebrow">Contato</p>
                    <h2 id="contato-heading">{contact.headline}</h2>
                    <p style="color: var(--text-muted); max-width: 48ch">{contact.lead}</p>
                    <ul class="contact-facts">
                      <li>
                        <strong>E-mail:</strong>{" "}
                        <a href={`mailto:${brand.email}`}>{brand.email}</a>
                      </li>
                      <li>
                        <strong>WhatsApp:</strong>{" "}
                        <a href={`https://wa.me/${brand.whatsapp}`} target="_blank" rel="noopener noreferrer">
                          {brand.whatsappDisplay}
                        </a>
                      </li>
                      <li><strong>Planos:</strong> {commercial.plansNote}</li>
                    </ul>
                  </div>
                  <LeadForm />
                </div>
              </div>
            </article>

          </div>
        </div>
      </main>
    </div>
  </div>

  <HomeSpaMotion />
</BaseLayout>
