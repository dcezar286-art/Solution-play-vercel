---
import BaseLayout from "../layouts/BaseLayout.astro";
import MarqueeStrip from "../components/MarqueeStrip.astro";
import ServiceTabs from "../components/ServiceTabs.astro";
import LeadForm from "../components/LeadForm.astro";
import HomeSpaMotion from "../components/HomeSpaMotion.astro";
import InteractiveTopNav from "../components/InteractiveTopNav.astro";
import BenefitsRow from "../components/BenefitsRow.astro";
import HeroOutlineSvg from "../components/HeroOutlineSvg.astro";
import NetworkBackdrop from "../components/NetworkBackdrop.astro";
import CommercialCornerBeams from "../components/CommercialCornerBeams.astro";
import CommercialMSP from "../components/CommercialMSP.astro";
import { getImage } from "astro:assets";
import BrandLogo from "../components/BrandLogo.astro";
import ContactTrustIcons from "../components/ContactTrustIcons.astro";
import { brand, hero, commercial, contact } from "../data/marketingContent";
import { siteSeo } from "../data/seo";
import heroLogoSrc from "../../LOGO/SolutionPlay.png";

const heroLogoPreload = (
  await getImage({
    src: heroLogoSrc,
    width: 128,
    height: 128,
    format: "webp",
  })
).src;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteSeo.siteName,
  url: siteSeo.siteUrl,
  email: brand.email,
  telephone: brand.whatsappDisplay,
  taxID: brand.cnpj,
  description: siteSeo.defaultDescription,
};
---

<BaseLayout
  title={siteSeo.defaultTitle}
  homeSpa={true}
  heroLogoPreload={heroLogoPreload}
>
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <div class="spa-layout">
    <InteractiveTopNav />

    <div class="spa-stage">
      <main id="conteudo-principal" class="spa-main">
        <div class="spa-viewport">
          <div class="spa-track">
            <article class="spa-slide is-active" data-slide="hero" aria-hidden="false">
              <div class="spa-slide__inner hero hero--studio hero--center" aria-labelledby="hero-heading">
                <NetworkBackdrop variant="hero" />
                <div class="wrap hero-studio-grid hero-studio-grid--single">
                  <div class="hero-studio-copy">
                    <div class="hero-brand-row">
                      <BrandLogo
                        class="hero-brand-mark"
                        width={64}
                        height={64}
                        loading="eager"
                        fetchpriority="high"
                      />
                      <p class="hero-slogan">
                        Tecnologia que resolve. Soluções que <span class="hero-slogan__accent">impulsionam</span>.
                      </p>
                    </div>

                    <h1 id="hero-heading" class="hero-mega hero-mega--data-beam">
                      {
                        hero.headlineLines.map((line) =>
                          line.variant === "outline" ? (
                            <HeroOutlineSvg text={line.text} />
                          ) : (
                            <span
                              class:list={[
                                "hero-mega__line",
                                line.variant === "solid" && "hero-mega__line--solid",
                                line.variant === "accent" && "hero-mega__line--accent",
                              ]}
                            >
                              {line.text}
                            </span>
                          ),
                        )
                      }
                    </h1>

                    <p class="hero-lead hero-lead--studio">{hero.lead}</p>
                    <BenefitsRow />
                    <div class="hero-studio-foot">
                      <div class="hero-ctas">
                        <button type="button" class="btn btn-primary" data-slide-jump="contact">
                          Formulário
                        </button>
                        <button type="button" class="btn btn-ghost" data-slide-jump="services">
                          Nossos serviços
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </article>

            <article class="spa-slide" data-slide="services" aria-hidden="true">
              <div class="spa-slide__inner spa-slide__inner--services">
                <NetworkBackdrop variant="services" />
                <div class="services-slide-content">
                  <MarqueeStrip />
                  <ServiceTabs />
                </div>
              </div>
            </article>

            <article class="spa-slide" data-slide="commercial" aria-hidden="true">
              <div class="spa-slide__inner section commercial commercial--studio" aria-labelledby="comercial-heading">
                <NetworkBackdrop variant="commercial" />
                <CommercialCornerBeams variant="viewport" />
                <div class="wrap commercial-inner commercial-inner--above commercial-inner--spa">
                  <div class="commercial-main">
                    <h2 id="comercial-heading" class="section-eyebrow commercial-page-title">
                      {commercial.headline}
                    </h2>
                    <CommercialMSP />
                  </div>
                </div>
              </div>
            </article>

            <article class="spa-slide" data-slide="contact" aria-hidden="true">
              <div class="spa-slide__inner section lead-section lead-section--studio spa-slide__inner--contact" aria-labelledby="contato-heading">
                <NetworkBackdrop variant="contact" />
                <div class="wrap lead-grid contact-slide-content">
                  <div class="contact-aside">
                    <p class="section-eyebrow">Contato</p>
                    <p class="contact-service-badge">
                      <ContactTrustIcons name="headset" class="contact-service-badge__icon" />
                      <span>{contact.badge}</span>
                    </p>
                    <h2 id="contato-heading">{contact.headline}</h2>
                    <p class="contact-aside__lead">{contact.lead}</p>
                    <ul class="contact-facts">
                      <li>
                        <strong>E-mail:</strong>{" "}
                        <a href={`mailto:${brand.email}`}>{brand.email}</a>
                      </li>
                      <li>
                        <strong>WhatsApp:</strong>{" "}
                        <a href={`https://wa.me/${brand.whatsapp}`} target="_blank" rel="noopener noreferrer">
                          {brand.whatsappDisplay}
                        </a>
                      </li>
                      <li><strong>Planos:</strong> {commercial.plansNote}</li>
                    </ul>
                    <ul class="contact-trust" aria-label="Garantias de atendimento">
                      {
                        contact.trustItems.map((item) => (
                          <li class="contact-trust__item">
                            <span class="contact-trust__icon" aria-hidden="true">
                              <ContactTrustIcons name={item.icon} />
                            </span>
                            <span class="contact-trust__text">
                              <strong>{item.title}</strong>
                              <span>{item.desc}</span>
                            </span>
                          </li>
                        ))
                      }
                    </ul>
                  </div>
                  <LeadForm />
                </div>
              </div>
            </article>

          </div>
        </div>
      </main>
    </div>
  </div>

  <HomeSpaMotion />
</BaseLayout>
