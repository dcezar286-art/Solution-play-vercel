---
import { brand } from "../data/marketingContent";
---

<form id="lead-form" class="form-card" novalidate data-reveal style="--reveal-delay: 100ms">
  <h2>Fale com a equipe</h2>
  <p>Informe seu nome e perfil. Ao enviar, abrimos o WhatsApp com a mensagem pronta.</p>

  <div class="field">
    <label for="nome">Nome</label>
    <input id="nome" name="nome" type="text" autocomplete="name" required maxlength="120" placeholder="Seu nome" />
  </div>

  <div class="field">
    <label for="perfil">Perfil</label>
    <select id="perfil" name="perfil" required>
      <option value="" disabled selected>Selecione…</option>
      <option value="Empresa — MSP / contrato mensal">Empresa — MSP / contrato mensal</option>
      <option value="Serviços avulsos / projeto pontual">Serviços avulsos / projeto pontual</option>
      <option value="Outro / a definir">Outro / a definir</option>
    </select>
  </div>

  <div class="form-actions">
    <button class="btn btn-primary" type="submit">Abrir no WhatsApp</button>
  </div>
</form>

<script define:vars={{ whatsapp: brand.whatsapp }}>
  function buildMessage() {
    const form = document.getElementById("lead-form");
    if (!(form instanceof HTMLFormElement)) return "";
    const fd = new FormData(form);
    const nome = String(fd.get("nome") || "").trim();
    const perfil = String(fd.get("perfil") || "").trim();
    return ["Olá, Solution Play — contato pelo site.", "", `Nome: ${nome}`, `Perfil: ${perfil}`].join("\n");
  }

  const form = document.getElementById("lead-form");

  if (form instanceof HTMLFormElement) {
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      const text = encodeURIComponent(buildMessage());
      const url = `https://wa.me/${whatsapp}?text=${text}`;
      window.open(url, "_blank", "noopener,noreferrer");
    });
  }
</script>
