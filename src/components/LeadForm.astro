---
---

<form id="lead-form" class="form-card" novalidate data-reveal style="--reveal-delay: 100ms">
  <h2>Fale com a equipe</h2>
  <p>Preencha os campos. Você será direcionado ao WhatsApp com a mensagem montada — número de exemplo nesta amostra.</p>

  <div class="field">
    <label for="nome">Nome</label>
    <input id="nome" name="nome" type="text" autocomplete="name" required maxlength="120" placeholder="Seu nome" />
  </div>

  <div class="field">
    <label for="perfil">Perfil</label>
    <select id="perfil" name="perfil" required>
      <option value="" disabled selected>Selecione…</option>
      <option value="Empresa — TI">Empresa — TI</option>
      <option value="Provedor — Telecom">Provedor — Telecom</option>
      <option value="Outro / ainda definindo">Outro / ainda definindo</option>
    </select>
  </div>

  <div class="field">
    <label for="telefone">Telefone (com DDD)</label>
    <input
      id="telefone"
      name="telefone"
      type="tel"
      autocomplete="tel"
      required
      maxlength="20"
      placeholder="(__) _____-____"
    />
  </div>

  <div class="field">
    <label for="mensagem">Mensagem</label>
    <textarea id="mensagem" name="mensagem" required maxlength="2000" placeholder="Conte brevemente a necessidade…"
    ></textarea>
  </div>

  <div class="form-actions">
    <button class="btn btn-primary" type="submit">Abrir no WhatsApp</button>
    <button class="btn btn-ghost" type="button" id="lead-copy">Copiar mensagem</button>
  </div>

  <p class="note-box" style="margin-top: 1rem">
    <strong>Institucional (demo):</strong> número comercial, WhatsApp corporativo e CNPJ seguem o
    <strong>site oficial publicado</strong> — aqui não há dados reais, apenas fluxo de contato para revisão de UX.
  </p>
</form>

<script>
  // TODO: substituir pelo número publicado no site do cliente (E.164, apenas dígitos após wa.me/)
  const WHATSAPP_E164 = "5511999999999";

  function buildMessage() {
    const form = document.getElementById("lead-form");
    if (!(form instanceof HTMLFormElement)) return "";
    const fd = new FormData(form);
    const nome = String(fd.get("nome") || "").trim();
    const perfil = String(fd.get("perfil") || "").trim();
    const telefone = String(fd.get("telefone") || "").trim();
    const mensagem = String(fd.get("mensagem") || "").trim();
    return [
      "Olá, Solution Play — contato pelo site (amostra Vercel).",
      "",
      `Nome: ${nome}`,
      `Perfil: ${perfil}`,
      `Telefone: ${telefone}`,
      "",
      "Mensagem:",
      mensagem,
    ].join("\n");
  }

  const form = document.getElementById("lead-form");
  const copyBtn = document.getElementById("lead-copy");

  if (form instanceof HTMLFormElement) {
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      const text = encodeURIComponent(buildMessage());
      const url = `https://wa.me/${WHATSAPP_E164}?text=${text}`;
      window.open(url, "_blank", "noopener,noreferrer");
    });
  }

  copyBtn?.addEventListener("click", async () => {
    const formEl = document.getElementById("lead-form");
    if (!(formEl instanceof HTMLFormElement)) return;
    if (!formEl.checkValidity()) {
      formEl.reportValidity();
      return;
    }
    const msg = buildMessage();
    try {
      await navigator.clipboard.writeText(msg);
      copyBtn.textContent = "Copiado!";
      setTimeout(() => {
        copyBtn.textContent = "Copiar mensagem";
      }, 2200);
    } catch {
      copyBtn.textContent = "Não foi possível copiar";
      setTimeout(() => {
        copyBtn.textContent = "Copiar mensagem";
      }, 2200);
    }
  });
</script>
