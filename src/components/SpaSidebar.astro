---
import BrandLogo from "./BrandLogo.astro";

const items = [
  { id: "hero", num: "01", label: "Início", from: "#22d3ee", to: "#5eead4" },
  { id: "services", num: "02", label: "Serviços", from: "#5eead4", to: "#6366f1" },
  { id: "commercial", num: "03", label: "Contratos", from: "#2dd4bf", to: "#22d3ee" },
  { id: "contact", num: "04", label: "Contato", from: "#22d3ee", to: "#38bdf8" },
];
---

<aside class="spa-sidebar" aria-label="Navegação principal">
  <a class="spa-sidebar__logo" href="/" data-slide-jump="hero" aria-label="Solution Play — início">
    <BrandLogo class="spa-sidebar__logo-mark" width={44} height={44} loading="eager" />
    <span class="spa-sidebar__logo-text">
      Solution <span class="logo__accent">Play</span>
    </span>
  </a>

  <nav class="spa-sidebar__nav" aria-label="Secções">
    <ul class="spa-sidebar__menu">
      {
        items.map((item, i) => (
          <li class="spa-sidebar__menu-item">
            <button
              type="button"
              class:list={["spa-sidebar__item", { "is-active": i === 0 }]}
              data-slide-jump={item.id}
              style={`--item-from: ${item.from}; --item-to: ${item.to}`}
              aria-current={i === 0 ? "page" : undefined}
              aria-label={`${item.num} ${item.label}`}
            >
              <span class="spa-sidebar__glow" aria-hidden="true"></span>
              <span class="spa-sidebar__glass" aria-hidden="true"></span>
              <span class="spa-sidebar__content">
                <span class="spa-sidebar__num">{item.num}</span>
                <span class="spa-sidebar__label">{item.label}</span>
              </span>
            </button>
          </li>
        ))
      }
    </ul>
  </nav>

  <div class="spa-sidebar__footer">
    <button type="button" class="btn btn-primary spa-sidebar__cta" data-slide-jump="contact">
      Contato
    </button>
  </div>
</aside>
