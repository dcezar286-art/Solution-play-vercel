---
/** Feixes vindos dos cantos da tela + contorno animado em volta dos cards (Contratos). */

interface Props {
  variant: "viewport" | "frame";
}

const { variant } = Astro.props;
---

{
  variant === "viewport" ? (
    <div class="commercial-viewport-beams" aria-hidden="true">
      <span class="commercial-viewport-beam commercial-viewport-beam--tl" />
      <span class="commercial-viewport-beam commercial-viewport-beam--tr" />
      <span class="commercial-viewport-beam commercial-viewport-beam--bl" />
      <span class="commercial-viewport-beam commercial-viewport-beam--br" />
      <span class="commercial-viewport-beam commercial-viewport-beam--tl2" />
      <span class="commercial-viewport-beam commercial-viewport-beam--tr2" />
      <span class="commercial-viewport-beam commercial-viewport-beam--bl2" />
      <span class="commercial-viewport-beam commercial-viewport-beam--br2" />
    </div>
  ) : (
    <div class="commercial-frame-beams" aria-hidden="true">
      <span class="commercial-frame-beams__edge commercial-frame-beams__edge--top" />
      <span class="commercial-frame-beams__edge commercial-frame-beams__edge--right" />
      <span class="commercial-frame-beams__edge commercial-frame-beams__edge--bottom" />
      <span class="commercial-frame-beams__edge commercial-frame-beams__edge--left" />
      <span class="commercial-frame-beams__runner commercial-frame-beams__runner--top" />
      <span class="commercial-frame-beams__runner commercial-frame-beams__runner--right" />
      <span class="commercial-frame-beams__runner commercial-frame-beams__runner--bottom" />
      <span class="commercial-frame-beams__runner commercial-frame-beams__runner--left" />
    </div>
  )
}

<style>
  /* --- Feixes dos cantos da viewport (slide Contratos) --- */
  .commercial-viewport-beams {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
    pointer-events: none;
  }

  .commercial-viewport-beam {
    position: absolute;
    height: 1px;
    width: min(42vw, 520px);
    border-radius: 1px;
    opacity: 0;
    background: linear-gradient(
      90deg,
      rgba(34, 211, 238, 0.65) 0%,
      rgba(160, 240, 220, 0.35) 45%,
      transparent 100%
    );
    box-shadow: 0 0 14px rgba(34, 211, 238, 0.35);
    animation: commercial-viewport-beam 8s ease-in-out infinite;
  }

  .commercial-viewport-beam--tl {
    top: 6%;
    left: 0;
    transform: rotate(22deg);
    transform-origin: left center;
    animation-delay: 0s;
  }

  .commercial-viewport-beam--tr {
    top: 6%;
    right: 0;
    left: auto;
    transform: rotate(-22deg);
    transform-origin: right center;
    background: linear-gradient(270deg, rgba(34, 211, 238, 0.65) 0%, rgba(160, 240, 220, 0.35) 45%, transparent 100%);
    animation-delay: -1s;
  }

  .commercial-viewport-beam--bl {
    bottom: 10%;
    left: 0;
    transform: rotate(-20deg);
    transform-origin: left center;
    background: linear-gradient(90deg, rgba(29, 158, 117, 0.55) 0%, rgba(160, 240, 220, 0.28) 50%, transparent 100%);
    animation-delay: -2.2s;
  }

  .commercial-viewport-beam--br {
    bottom: 10%;
    right: 0;
    left: auto;
    transform: rotate(20deg);
    transform-origin: right center;
    background: linear-gradient(270deg, rgba(29, 158, 117, 0.55) 0%, rgba(160, 240, 220, 0.28) 50%, transparent 100%);
    animation-delay: -3.4s;
  }

  .commercial-viewport-beam--tl2 {
    top: 0;
    left: 0;
    width: 1px;
    height: min(32vh, 280px);
    background: linear-gradient(180deg, rgba(34, 211, 238, 0.55) 0%, transparent 100%);
    box-shadow: 0 0 12px rgba(34, 211, 238, 0.28);
    animation-name: commercial-viewport-beam-v;
    animation-delay: -0.6s;
  }

  .commercial-viewport-beam--tr2 {
    top: 0;
    right: 0;
    left: auto;
    width: 1px;
    height: min(32vh, 280px);
    background: linear-gradient(180deg, rgba(34, 211, 238, 0.55) 0%, transparent 100%);
    box-shadow: 0 0 12px rgba(34, 211, 238, 0.28);
    animation-name: commercial-viewport-beam-v;
    animation-delay: -1.8s;
  }

  .commercial-viewport-beam--bl2 {
    bottom: 0;
    left: 0;
    width: 1px;
    height: min(28vh, 240px);
    background: linear-gradient(0deg, rgba(29, 158, 117, 0.5) 0%, transparent 100%);
    animation-name: commercial-viewport-beam-v;
    animation-delay: -2.8s;
  }

  .commercial-viewport-beam--br2 {
    bottom: 0;
    right: 0;
    left: auto;
    width: 1px;
    height: min(28vh, 240px);
    background: linear-gradient(0deg, rgba(29, 158, 117, 0.5) 0%, transparent 100%);
    animation-name: commercial-viewport-beam-v;
    animation-delay: -4s;
  }

  @keyframes commercial-viewport-beam {
    0% {
      opacity: 0;
      filter: blur(2px);
    }
    12% {
      opacity: 0.85;
      filter: blur(0);
    }
    55% {
      opacity: 0.55;
    }
    100% {
      opacity: 0;
      filter: blur(1px);
    }
  }

  @keyframes commercial-viewport-beam-v {
    0% {
      opacity: 0;
    }
    15% {
      opacity: 0.75;
    }
    60% {
      opacity: 0.4;
    }
    100% {
      opacity: 0;
    }
  }

  /* --- Contorno em volta dos cards --- */
  .commercial-frame-beams {
    position: absolute;
    inset: -16px -14px;
    z-index: 0;
    pointer-events: none;
  }

  .commercial-frame-beams__edge {
    position: absolute;
    opacity: 0.35;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(34, 211, 238, 0.25) 50%,
      transparent
    );
  }

  .commercial-frame-beams__edge--top,
  .commercial-frame-beams__edge--bottom {
    left: 12px;
    right: 12px;
    height: 1px;
  }

  .commercial-frame-beams__edge--top {
    top: 0;
  }

  .commercial-frame-beams__edge--bottom {
    bottom: 0;
    background: linear-gradient(270deg, transparent, rgba(34, 211, 238, 0.25) 50%, transparent);
  }

  .commercial-frame-beams__edge--left,
  .commercial-frame-beams__edge--right {
    top: 12px;
    bottom: 12px;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(29, 158, 117, 0.28) 50%, transparent);
  }

  .commercial-frame-beams__edge--left {
    left: 0;
  }

  .commercial-frame-beams__edge--right {
    right: 0;
  }

  .commercial-frame-beams__runner {
    position: absolute;
    border-radius: 2px;
    opacity: 0;
    box-shadow: 0 0 10px rgba(34, 211, 238, 0.55);
  }

  .commercial-frame-beams__runner--top,
  .commercial-frame-beams__runner--bottom {
    top: -1px;
    height: 2px;
    width: 18%;
    background: linear-gradient(90deg, transparent, #5eead4, transparent);
    animation: commercial-frame-runner-h 5.5s linear infinite;
  }

  .commercial-frame-beams__runner--bottom {
    top: auto;
    bottom: -1px;
    animation-direction: reverse;
    animation-delay: -2.75s;
  }

  .commercial-frame-beams__runner--left,
  .commercial-frame-beams__runner--right {
    left: -1px;
    width: 2px;
    height: 18%;
    background: linear-gradient(180deg, transparent, #5eead4, transparent);
    animation: commercial-frame-runner-v 5.5s linear infinite;
    animation-delay: -1.35s;
  }

  .commercial-frame-beams__runner--right {
    left: auto;
    right: -1px;
    animation-delay: -4.1s;
  }

  @keyframes commercial-frame-runner-h {
    0% {
      left: -5%;
      opacity: 0;
    }
    8% {
      opacity: 1;
    }
    92% {
      opacity: 0.85;
    }
    100% {
      left: 87%;
      opacity: 0;
    }
  }

  @keyframes commercial-frame-runner-v {
    0% {
      top: -5%;
      opacity: 0;
    }
    8% {
      opacity: 1;
    }
    92% {
      opacity: 0.85;
    }
    100% {
      top: 87%;
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .commercial-viewport-beam {
      animation: none;
      opacity: 0.2;
    }

    .commercial-frame-beams__runner {
      animation: none;
      opacity: 0.35;
    }

    .commercial-frame-beams__runner--top {
      left: 30%;
    }

    .commercial-frame-beams__runner--bottom {
      left: 55%;
    }

    .commercial-frame-beams__runner--left {
      top: 25%;
    }

    .commercial-frame-beams__runner--right {
      top: 60%;
    }
  }
</style>
