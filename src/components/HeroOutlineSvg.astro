---
interface Props {
  text: string;
}

const { text } = Astro.props;
const label = text.toUpperCase();
---

<span class="hero-mega__line hero-mega__line--outline-svg" style="animation-delay: 0.14s">
  <svg
    class="hero-outline-svg"
    viewBox="0 0 1000 96"
    preserveAspectRatio="xMidYMid meet"
    role="img"
    aria-label={text}
  >
    <text
      class="hero-outline-svg__text hero-outline-svg__text--base"
      x="500"
      y="70"
      text-anchor="middle"
      fill="#030308"
      stroke="currentColor"
      stroke-width="1.15"
      stroke-linejoin="round"
      stroke-linecap="round"
      paint-order="stroke fill"
      textLength="940"
      lengthAdjust="spacingAndGlyphs"
    >
      {label}
    </text>
    <text
      class="hero-outline-svg__text hero-outline-svg__text--beam"
      x="500"
      y="70"
      text-anchor="middle"
      fill="#030308"
      stroke="currentColor"
      stroke-width="1.15"
      stroke-linejoin="round"
      stroke-linecap="round"
      paint-order="stroke fill"
      textLength="940"
      lengthAdjust="spacingAndGlyphs"
    >
      {label}
    </text>
  </svg>
</span>
