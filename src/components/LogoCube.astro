---
import logoUrl from "../../LOGO/SolutionPlay.png?url";
---

<div
  id="logo-cube-root"
  class="logo-cube"
  data-logo-src={logoUrl}
  role="img"
  aria-label="Cubo 3D em arame com a marca no centro. Mova o ponteiro para inclinar."
>
  <canvas class="logo-cube__canvas" width="600" height="600"></canvas>
  <img class="logo-cube__fallback" src={logoUrl} alt="Logo Solution Play" loading="lazy" width="512" height="512" />
  <p class="logo-cube__hint" aria-hidden="true">Cubo em arame · marca no centro</p>
</div>

<script>
  import "../scripts/logoCubeBoot.ts";
</script>
