---
import logoUrl from "../../LOGO/SolutionPlay-removebg-preview.png?url";

const scenes = [
  { id: "hero", tone: "radial-gradient(ellipse 90% 70% at 50% 20%, rgba(34, 211, 238, 0.22), transparent 58%)" },
  { id: "services", tone: "radial-gradient(ellipse 80% 60% at 20% 80%, rgba(99, 102, 241, 0.2), transparent 55%)" },
  { id: "commercial", tone: "radial-gradient(ellipse 70% 55% at 85% 30%, rgba(45, 212, 191, 0.18), transparent 52%)" },
  { id: "contact", tone: "radial-gradient(ellipse 75% 65% at 50% 100%, rgba(34, 211, 238, 0.14), transparent 50%)" },
  { id: "dono", tone: "radial-gradient(ellipse 60% 50% at 50% 50%, rgba(168, 85, 247, 0.16), transparent 58%)" },
  { id: "footer", tone: "radial-gradient(ellipse 100% 40% at 50% 0%, rgba(14, 165, 233, 0.12), transparent 48%)" },
];
---

<div class="scene-backdrop" aria-hidden="true">
  <div class="scene-backdrop__cube-wrap" data-cube-wrap>
    <div class="scene-backdrop__cube-beams" aria-hidden="true">
      <span class="scene-backdrop__beam scene-backdrop__beam--a"></span>
      <span class="scene-backdrop__beam scene-backdrop__beam--b"></span>
      <span class="scene-backdrop__beam scene-backdrop__beam--c"></span>
    </div>
    <img
      class="scene-backdrop__cube"
      data-cube-img
      src={logoUrl}
      alt=""
      width="512"
      height="512"
      decoding="async"
    />
  </div>
  {
    scenes.map((s, i) => (
      <div
        class:list={["scene-backdrop__layer", { "is-active": i === 0 }]}
        data-scene-backdrop={s.id}
        style={`--scene-tone: ${s.tone}`}
      />
    ))
  }
  <div class="scene-backdrop__noise"></div>
</div>
