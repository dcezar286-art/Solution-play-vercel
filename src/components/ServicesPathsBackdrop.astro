---
import { buildFloatingPaths } from "../data/servicesPathsData";

const pathsA = buildFloatingPaths(1);
const pathsB = buildFloatingPaths(-1);
---

<div class="services-paths-host" data-services-paths-host aria-hidden="true">
  <div class="services-paths-layer" data-services-paths-layer="1">
    <svg class="services-paths-svg" viewBox="0 0 696 316" fill="none" preserveAspectRatio="xMidYMid slice">
      <title>Background paths</title>
      {
        pathsA.map((path) => (
          <path
            class="services-paths-stroke"
            data-services-path
            d={path.d}
            stroke-width={path.width}
            stroke-opacity={path.opacity}
          />
        ))
      }
    </svg>
  </div>
  <div class="services-paths-layer" data-services-paths-layer="-1">
    <svg class="services-paths-svg" viewBox="0 0 696 316" fill="none" preserveAspectRatio="xMidYMid slice">
      <title>Background paths mirrored</title>
      {
        pathsB.map((path) => (
          <path
            class="services-paths-stroke"
            data-services-path
            d={path.d}
            stroke-width={path.width}
            stroke-opacity={path.opacity}
          />
        ))
      }
    </svg>
  </div>
</div>

<script>
  import "../scripts/servicesPathsBoot.ts";
</script>
