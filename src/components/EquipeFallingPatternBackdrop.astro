---
import {
  buildFallingPatternBackground,
  FALLING_PATTERN_BG_SIZES,
  FALLING_PATTERN_DEFAULTS,
  FALLING_PATTERN_END_POSITIONS,
  FALLING_PATTERN_START_POSITIONS,
} from "../data/equipeFallingPatternData";

const { color, backgroundColor, duration, blurIntensity, density } = FALLING_PATTERN_DEFAULTS;
const bgImage = buildFallingPatternBackground(color);
const meshSize = `${8 * density}px ${8 * density}px`;
---

<div class="equipe-falling-host" data-equipe-falling-host aria-hidden="true">
  <div
    class="equipe-falling-pattern"
    data-equipe-falling-pattern
    style={{
      "--equipe-fall-duration": `${duration}s`,
      "--equipe-fall-start": FALLING_PATTERN_START_POSITIONS,
      "--equipe-fall-end": FALLING_PATTERN_END_POSITIONS,
      backgroundColor,
      backgroundImage: bgImage,
      backgroundSize: FALLING_PATTERN_BG_SIZES,
    }}
  ></div>
  <div
    class="equipe-falling-overlay"
    style={{
      backdropFilter: `blur(${blurIntensity})`,
      backgroundImage: `radial-gradient(circle at 50% 50%, transparent 0, transparent 2px, ${backgroundColor} 2px)`,
      backgroundSize: meshSize,
    }}
  ></div>
</div>
