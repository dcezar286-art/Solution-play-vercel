---
const items = [
  "MSP Solution Play",
  "START · ESSENCIAL · PROFISSIONAL",
  "BUSINESS · ENTERPRISE",
  "Monitoramento e backup",
  "Active Directory e servidores",
  "Suporte remoto e presencial",
  "Contratos mensais flexíveis",
  "Valores na página Contratos",
];
const doubled = [...items, ...items];
---

<div class="marquee-strip" role="presentation" aria-hidden="true">
  <div class="marquee-strip__inner">
    {
      doubled.map((t) => (
        <span class="marquee-strip__item">{t}</span>
      ))
    }
  </div>
</div>
