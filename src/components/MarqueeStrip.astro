---
const items = [
  "Manutenção de PCs",
  "Active Directory",
  "Backup em nuvem",
  "Suporte técnico",
  "Servidores de arquivos",
  "Wi‑Fi corporativo",
  "Segurança",
  "Planos flexíveis",
  "Contrato a partir de R$ 300",
];
const doubled = [...items, ...items];
---

<div class="marquee-strip" role="presentation" aria-hidden="true">
  <div class="marquee-strip__inner">
    {
      doubled.map((t) => (
        <span class="marquee-strip__item">{t}</span>
      ))
    }
  </div>
</div>
