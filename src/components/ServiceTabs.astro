---
import { mspIntro, mspPlans, differentiators } from "../data/marketingContent";
---

<section class="section section--spa-services" aria-labelledby="servicos-heading">
  <div class="wrap">
    <div class="section-head">
      <p class="section-eyebrow">{mspIntro.eyebrow}</p>
      <h2 id="servicos-heading" class="msp-scramble-heading">
        <span class="msp-scramble-heading__track" tabindex="0">
          <span class="msp-scramble-heading__chars" data-text-scramble data-scramble-text={mspIntro.title}>
            {mspIntro.title}
          </span>
        </span>
        <span class="msp-scramble-heading__line" aria-hidden="true"></span>
      </h2>
      <p>{mspIntro.lead}</p>
      <p class="section-head__hint">
        Valores e investimentos mensais estão na seção <strong>Contratos</strong>.
      </p>
    </div>

    <div class="msp-plan-list" role="list">
      {
        mspPlans.map((plan) => (
          <article
            class:list={["msp-skew-card", `msp-skew-card--${plan.id}`]}
            role="listitem"
            tabindex="0"
          >
            <span class="msp-skew-card__panel" aria-hidden="true"></span>
            <span class="msp-skew-card__panel msp-skew-card__panel--blur" aria-hidden="true"></span>
            <span class="msp-skew-card__blobs" aria-hidden="true">
              <span class="msp-skew-card__blob msp-skew-card__blob--a"></span>
              <span class="msp-skew-card__blob msp-skew-card__blob--b"></span>
            </span>
            <div class="msp-skew-card__inner">
              <header class="msp-plan-card__head">
                <h3 class="msp-plan-card__name">{plan.name}</h3>
              </header>
              <p class="msp-plan-card__scope msp-text-shimmer">{plan.scope}</p>
              <ul class="msp-plan-card__includes">
                {plan.includes.map((line) => (
                  <li>
                    <span class="msp-text-shimmer">{line}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>

    <div class="msp-block msp-block--diff">
      <h3 class="msp-block__title">Diferenciais Solution Play</h3>
      <ul class="msp-diff-list">
        {differentiators.map((line) => <li>{line}</li>)}
      </ul>
    </div>
  </div>
</section>

<script>
  import "../scripts/textScrambleBoot.ts";
</script>
